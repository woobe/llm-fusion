# Example fusion_config.yaml
# Copy this file to ~/.config/llm-fusion/fusion_config.yaml and edit.
#
# API key: set OPENCODE_GO_API_KEY in your environment or ~/.hermes/.env.
# Do NOT commit secrets to version control.

fusion:
  version: "2.0.0"
  classification:
    enabled: false
    confidence_threshold: 0.85
    llm_model: deepseek-v4-flash
    llm_temp: 0.0
    llm_max_tokens: 100
  default:
    panel:
      models:
        - name: deepseek-v4-flash
          count: 3
          temp: 0.75
          top_p: 0.9
          max_completion_tokens: 800
        - name: mimo-v2.5
          count: 3
          temps: [0.6, 0.7, 0.8]
          top_p: 0.95
          max_tokens: 600
          thinking:
            type: disabled
        - name: minimax-m3
          count: 0
          temp: 0.85
          top_p: 0.9
          top_k: 40
          max_tokens: 4096
          thinking:
            type: adaptive
        - name: qwen3.7-plus
          count: 0
          temp: 0.8
          top_p: 0.92
          top_k: 20
          reasoning_effort: high
          max_tokens: 4096
        - name: deepseek-v4-pro
          count: 0
          temp: 0.9
          top_p: 0.95
          reasoning_mode: high
          max_completion_tokens: 4096
    judge:
      model: mimo-v2.5
      temp: 1.0
      top_p: 0.95
      stages: single
      thinking:
        type: enabled
      max_tokens: 4096
      prompt_budget:
        enabled: true
  scenarios:
    coding:
      panel:
        deepseek:
          temp: 0.5
          max_completion_tokens: 2000
        mimo:
          temps: [0.4, 0.5, 0.6]
          max_tokens: 2000
      judge:
        stages: single
    bugfix:
      panel:
        deepseek:
          temp: 0.4
          max_completion_tokens: 2000
        mimo:
          temps: [0.4, 0.5, 0.6]
          max_tokens: 2000
      judge:
        stages: two
        max_panel_response_chars: 2000
        stage2_include_raw_responses: false
        stage1:
          max_tokens: 6144
        stage2:
          max_tokens: 6144
        prompt_budget:
          input_budget_chars: 24000
    qa:
      panel:
        deepseek:
          temp: 0.3
          max_completion_tokens: 800
        mimo:
          temps: [0.3, 0.4, 0.5]
          max_tokens: 800
      judge:
        stages: single
        max_panel_response_chars: 1200
        prompt_budget:
          input_budget_chars: 10000
    plan_review:
      panel:
        deepseek:
          temp: 0.6
          max_completion_tokens: 3000
        mimo:
          temps: [0.6, 0.7, 0.8]
          max_tokens: 2500
      judge:
        stages: two
        max_panel_response_chars: 2500
        stage2_include_raw_responses: false
        stage1:
          max_tokens: 6144
        stage2:
          max_tokens: 6144
        prompt_budget:
          input_budget_chars: 30000
    creative:
      panel:
        deepseek:
          temp: 1.0
          max_completion_tokens: 4000
        mimo:
          temps: [0.8, 0.9, 1.0]
          max_tokens: 2500
      judge:
        stages: single
    reasoning:
      panel:
        deepseek:
          temp: 0.5
          max_completion_tokens: 3000
        mimo:
          temps: [0.5, 0.6, 0.7]
          max_tokens: 2000
      judge:
        stages: two
        max_panel_response_chars: 2000
        stage2_include_raw_responses: false
        stage1:
          max_tokens: 6144
        stage2:
          max_tokens: 6144
        prompt_budget:
          input_budget_chars: 24000
    document:
      panel:
        deepseek:
          temp: 0.5
          max_completion_tokens: 4000
        mimo:
          temps: [0.5, 0.6, 0.7]
          max_tokens: 3000
      judge:
        stages: two
        max_panel_response_chars: 3000
        stage2_include_raw_responses: false
        stage1:
          max_tokens: 6144
        stage2:
          max_tokens: 6144
        prompt_budget:
          input_budget_chars: 32000
    general:
      panel:
        deepseek:
          temp: 0.75
          max_completion_tokens: 1200
        mimo:
          temps: [0.6, 0.7, 0.8]
          max_tokens: 1200
      judge:
        stages: single
        max_panel_response_chars: 1800
        prompt_budget:
          input_budget_chars: 16000
  cleaning:
    profiles:
      coding:
        strip_fences: false
        strip_preamble: true
        min_words: 15
        dedup_threshold: 0.70
      bugfix:
        strip_fences: true
        strip_preamble: true
        min_words: 15
        dedup_threshold: 0.75
      qa:
        strip_fences: true
        strip_preamble: true
        min_words: 5
        dedup_threshold: 0.85
      plan_review:
        strip_fences: true
        strip_preamble: true
        min_words: 30
        dedup_threshold: 0.80
      creative:
        strip_fences: true
        strip_preamble: true
        min_words: 10
        dedup_threshold: 0.60
      reasoning:
        strip_fences: true
        strip_preamble: true
        min_words: 20
        dedup_threshold: 0.75
      document:
        strip_fences: true
        strip_preamble: true
        min_words: 30
        dedup_threshold: 0.80
      general:
        strip_fences: true
        strip_preamble: true
        min_words: 10
        dedup_threshold: 0.85
  api:
    primary:
      endpoint: "https://opencode.ai/zen/go/v1/chat/completions"
      timeout:
        panel_floor: 60
        judge_floor: 90
        panel_throughput: 25
        judge_throughput: 20
        overhead_seconds: 15
        max_timeout: 360
      retry:
        max_retries: 2
        delays_seconds: [1, 3]
        retryable_statuses: [408, 409, 425, 429, 500, 502, 503, 504]
        non_retryable_statuses: [400, 401, 403, 404]
        backoff:
          enabled: true
          base_delay_seconds: 1.0
          max_delay_seconds: 30.0
          jitter_ratio: 0.25
    rate_limit:
      enabled: true
      requests_per_second: 10.0
      burst: 20
    fallback:
      enabled: false
      provider: openrouter
      endpoint: "https://openrouter.ai/api/v1/chat/completions"
  pipeline:
    default_tier: medium
    max_panel_workers: 6
    min_survivors: 2
    quorum_by_tier:
      low1: 2
      low2: 0
      low3: 0
      medium: 3
      high: 3
    min_survivors_by_tier:
      low1: 2
      low2: 3
      low3: 5
      medium: 3
      high: 3
    soft_deadline_seconds: 300
    graceful_degradation: true
    express_qa:
      enabled: true
      max_chars: 120
      min_confidence: 0.85
      model: deepseek-v4-flash
      temperature: 0.0
      max_completion_tokens: 1200
      detection_method: regex
      exclude_patterns:
        - "\\bexplain\\b"
        - "\\bcompare\\b"
        - "\\bdescribe\\b"
        - "\\bdifference between\\b"
        - "\\bhow does\\b"
        - "\\bwhy does\\b"
        - "\\bwith examples?\\b"
    direct_fallback:
      model: deepseek-v4-flash
      temperature: 0.75
      top_p: 0.9
      max_tokens: 2000
      timeout: null
      retries: 1
      delays_seconds: [2]
    retry:
      low1:
        max_retries: 0
        delays_seconds: []
      low2:
        max_retries: 1
        delays_seconds: [1]
      low3:
        max_retries: 1
        delays_seconds: [1]
      medium:
        max_retries: 1
        delays_seconds: [1]
      high:
        max_retries: 2
        delays_seconds: [1, 3]
